
{
  "entities": {
    "Video": {
      "title": "Video",
      "description": "Metadata for a ministry video.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "videoUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "likesCount": { "type": "number" },
        "likedBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "videoUrl", "thumbnailUrl"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "A ministry journal entry or article.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string", "description": "Optional video embed for the blog." },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "published": { "type": "boolean" },
        "likesCount": { "type": "number" },
        "likedBy": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "content", "imageUrl"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A user comment on a content piece.",
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "text", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/videos/{videoId}": {
      "schema": "#/backend/entities/Video",
      "description": "Collection of videos uploaded by the ministry admin."
    },
    "/blogs/{blogId}": {
      "schema": "#/backend/entities/BlogPost",
      "description": "Collection of blog posts and articles."
    },
    "/blogs/{blogId}/comments/{commentId}": {
      "schema": "#/backend/entities/Comment",
      "description": "Comments nested under blog posts."
    }
  }
}
